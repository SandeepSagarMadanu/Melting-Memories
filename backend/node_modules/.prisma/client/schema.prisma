datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum CustomOrderStatus {
  PENDING
  APPROVED
  REJECTED
  CONTACTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  reviews   Review[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  salePrice   Float?
  inventory   Int      @default(0)
  images      String[] // URLs of images
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  colors      String[] @default(["All Colors"])
  fragrances  String[] // ["Vintage Lilly", "Rose Bloom", "Chocolate", etc.]
  burnTime    String   @default("Approximately 4 Hours")
  weight      String   @default("Varies by size")
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reviews     Review[]
}

model Order {
  id                String            @id @default(uuid())
  orderNumber       String            @unique // E.g., MM-1001, MM-1002
  userId            String?
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName      String
  customerEmail     String
  customerPhone     String
  customerAddress   String
  items             Json // Array of { productId, name, price, quantity, fragrance, color }
  totalAmount       Float
  shippingFee       Float             @default(0)
  taxAmount         Float             @default(0)
  discountAmount    Float             @default(0)
  couponCode        String?
  paymentStatus     OrderStatus       @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  paymentId         String? // Razorpay payment/order ID
  trackingNumber    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model CustomOrder {
  id             String            @id @default(uuid())
  name           String
  email          String
  phone          String
  occasion       String // e.g. Wedding, Birthday, Anniversary, Corporate, Baby Shower, Other
  fragrance      String // Vintage Lilly, Rose Bloom, Chocolate, etc.
  customMessage  String?
  referenceImage String? // Cloudinary URL
  quantity       Int               @default(1)
  deliveryDate   DateTime
  status         CustomOrderStatus @default(PENDING)
  notes          String? // Admin notes
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  rating     Int      @default(5)
  comment    String
  image      String? // Optional reviewer image
  video      String? // Optional reviewer video
  isApproved Boolean  @default(false)
  isFeatured Boolean  @default(false)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String   @default("Anonymous")
  createdAt  DateTime @default(now())
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  image       String?
  category    String // Wedding Gifts, Birthday Gifts, Luxury Decor, Candle Care, Corporate Gifting
  readTime    String   @default("3 mins read")
  publishedAt DateTime @default(now())
}

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  discountType String // PERCENTAGE or FIXED
  value        Float
  expiryDate   DateTime
  usageLimit   Int      @default(100)
  timesUsed    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
